# CyPulse 環境變數（複製為 .env 並填入實際值）

# === API Keys（選填，不設定也能執行所有模組）===
# AbuseIPDB: 選填，免費註冊 https://www.abuseipdb.com（1,000 次/天）
# 設定後 M2 IP 信譽會額外使用 AbuseIPDB 資料（Shodan + GreyNoise 免費來源預設啟用）
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=

# === 通知設定 ===
SLACK_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=

# Email 通知（SMTP）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# === CyPulse 設定 ===
CYPULSE_OUTPUT_DIR=./data
CYPULSE_CONFIG=config/config.yaml
CYPULSE_LOG_LEVEL=INFO
