# CyPulse 環境變數（複製為 .env 並填入實際值）

# === API Keys ===
ABUSEIPDB_API_KEY=
HIBP_API_KEY=
URLSCAN_API_KEY=

# === 通知設定 ===
SLACK_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=

# Email 通知（SMTP）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# === CyPulse 設定 ===
CYPULSE_OUTPUT_DIR=./data
CYPULSE_CONFIG=config/config.yaml
CYPULSE_LOG_LEVEL=INFO
